   "outputs": [],
   "source": [
    "for name, results in [('Random Forest', rf_results), ('XGBoost', xgb_results)]:\n",
    "    best = max(results, key=lambda x: x['miou'])\n",
    "    print(f\"=== {name} ===\")\n",
    "    print(f\"  Best threshold: {best['threshold']:.2f}\")\n",
    "    print(f\"  mIoU:      {best['miou']:.3f}\")\n",
    "    print(f\"  F1:        {best['f1']:.3f}\")\n",
    "    print(f\"  Precision: {best['precision']:.3f}\")\n",
    "    print(f\"  Recall:    {best['recall']:.3f}\")\n",
    "    print(f\"  Accuracy:  {best['accuracy']:.3f}\")\n",
    "    print()\n",
    "\n",
    "# Full table for Random Forest\n",
    "print(f\"{'Threshold':>10} {'mIoU':>8} {'F1':>8} {'Precision':>10} {'Recall':>8} {'Accuracy':>10}\")\n",
    "print(\"-\" * 60)\n",
    "for r in rf_results:\n",
    "    print(f\"  {r['threshold']:>8.2f} {r['miou']:>8.3f} {r['f1']:>8.3f} \"\n",
    "          f\"{r['precision']:>10.3f} {r['recall']:>8.3f} {r['accuracy']:>10.3f}\")"
   ]
  },
  {
