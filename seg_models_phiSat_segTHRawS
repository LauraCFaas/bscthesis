   "source": [
    "# Ground truth\n",
    "np.save(os.path.join(data_dir, f'y_test_{DATASET}.npy'), y_test)\n",
    "\n",
    "# Majority class probabilities (threshold-independent)\n",
    "np.save(os.path.join(data_dir, f'y_prob_majority_{DATASET}.npy'), mc_probs)\n",
    "\n",
    "# Per-threshold results\n",
    "np.save(os.path.join(data_dir, f'results_rf_{DATASET}.npy'),  rf_results,  allow_pickle=True)\n",
    "np.save(os.path.join(data_dir, f'results_xgb_{DATASET}.npy'), xgb_results, allow_pickle=True)\n",
    "\n",
    "# Probs at threshold 0.5 for backwards compatibility with evaluation notebook\n",
    "t05_rf  = min(rf_results,  key=lambda x: abs(x['threshold'] - 0.5))\n",
