    "np.save(os.path.join(data_dir, f'y_prob_rf_{DATASET}.npy'),  t05_rf['probs'])\n",
    "np.save(os.path.join(data_dir, f'y_prob_xgb_{DATASET}.npy'), t05_xgb['probs'])\n",
    "\n",
    "print(f\"Saved results for {DATASET}:\")\n",
    "print(f\"  y_test_{DATASET}.npy\")\n",
    "print(f\"  y_prob_majority_{DATASET}.npy  — prior: {mc_probs[0]:.4f}\")\n",
    "print(f\"  results_rf_{DATASET}.npy       — {len(rf_results)} thresholds\")\n",
    "print(f\"  results_xgb_{DATASET}.npy      — {len(xgb_results)} thresholds\")"
   ]
