   "source": [
    "# Segmentation Models — PhiSat2 & segTHRawS\n",
    "\n",
    "Trains Majority Class, Random Forest and XGBoost for both segmentation datasets.\n",
    "Each model is trained once with balanced class weights, then evaluated at 19\n",
    "different thresholds (0.05-0.95) to produce a full performance curve per model.\n",
    "\n",
    "Set `DATASET` to either `'PhiSat2'` or `'segTHRawS'` to switch between datasets."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4d5ac361",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.ensemble import RandomForestClassifier\n",
    "from sklearn.dummy import DummyClassifier\n",
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.metrics import (\n",
    "    accuracy_score, classification_report,\n",
    "    jaccard_score, f1_score, precision_score, recall_score\n",
    ")\n",
    "from xgboost import XGBClassifier\n",
    "\n",
    "# ── CONFIG ──────────────────────────────────────────────────────────────────\n",
    "DATASET    = 'segTHRawS'   # Switch to 'segTHRawS' for the other dataset\n",
    "BASE_DIR   = '/home/laura/Scriptie/bewerkte_data'\n",
    "THRESHOLDS = np.linspace(0.05, 0.95, 19)\n",
    "CHUNK_SIZE = 500_000     # For chunked prediction on large arrays\n",
    "# ────────────────────────────────────────────────────────────────────────────\n",
    "\n",
    "data_dir = os.path.join(BASE_DIR, DATASET)\n",
    "print(f\"Dataset: {DATASET}\")\n",
    "print(f\"Data directory: {data_dir}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "40cb7354",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Load data\n",
    "\n",
    "if DATASET == 'PhiSat2':\n",
    "    X_dataset = np.load(os.path.join(data_dir, 'X_train_flat.npy'))\n",
    "    y_dataset = np.load(os.path.join(data_dir, 'y_train_flat.npy'))\n",
    "\n",
    "    # Subsample to avoid kernel crash on local machine\n",
    "    # Remove limits when running on HPC\n",
    "    train_size = min(100_000, int(len(X_dataset) * 0.7))\n",
    "    test_size  = min(50_000,  int(len(X_dataset) * 0.3))\n",
    "    X_train, X_test, y_train, y_test = train_test_split(\n",
    "        X_dataset, y_dataset,\n",
    "        train_size=train_size, test_size=test_size,\n",
    "        random_state=42\n",
    "    )\n",
    "\n",
    "elif DATASET == 'segTHRawS':\n",
    "    X_dataset = np.load(os.path.join(data_dir, 'X_train_segTHRawS.npy'))\n",
    "    y_dataset = np.load(os.path.join(data_dir, 'y_train_segTHRawS.npy'))\n",
    "\n",
    "    MAX_IMAGES = 200\n",
    "    if len(X_dataset) > MAX_IMAGES:\n",
    "        X_dataset = X_dataset[:MAX_IMAGES]\n",
    "        y_dataset = y_dataset[:MAX_IMAGES]\n",
    "\n",
    "    X_train_img, X_test_img, y_train_img, y_test_img = train_test_split(\n",
    "        X_dataset, y_dataset, test_size=0.20, random_state=42\n",
    "    )\n",
    "    # Flatten spatial dimensions for sklearn\n",
    "    X_train_full = X_train_img.reshape(-1, 3)\n",
    "    X_test_full  = X_test_img.reshape(-1, 3)\n",
    "    y_train_full = y_train_img.reshape(-1)\n",
    "    y_test_full  = y_test_img.reshape(-1)\n",
    "\n",
    "        # Subsample pixels to avoid kernel crash on local machine\n",
    "    # Remove limits when running on HPC\n",
    "    PIXEL_TRAIN_SIZE = 100_000\n",
    "    PIXEL_TEST_SIZE  = 50_000\n",
    "    if len(X_train_full) > PIXEL_TRAIN_SIZE:\n",
    "        X_train, _, y_train, _ = train_test_split(\n",
    "            X_train_full, y_train_full,\n",
    "            train_size=PIXEL_TRAIN_SIZE, random_state=42, stratify=y_train_full\n",
    "        )\n",
    "    else:\n",
    "        X_train, y_train = X_train_full, y_train_full\n",
    "\n",
    "    if len(X_test_full) > PIXEL_TEST_SIZE:\n",
    "        X_test, _, y_test, _ = train_test_split(\n",
    "            X_test_full, y_test_full,\n",
    "            train_size=PIXEL_TEST_SIZE, random_state=42, stratify=y_test_full\n",
    "        )\n",
    "    else:\n",
    "        X_test, y_test = X_test_full, y_test_full\n",
    "\n",
    "print(f\"Train: {X_train.shape}, Test: {X_test.shape}\")\n",
    "print(f\"Class distribution — 0: {(y_test==0).sum()}, 1: {(y_test==1).sum()}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "798538e5",
   "metadata": {},
   "source": [
    "## Majority Class Baseline\n",
    "\n",
    "Uses `strategy='prior'` which returns the class prior as a fixed probability for\n",
    "every pixel, producing a moving threshold curve in the evaluation notebook:\n",
    "below the prior all pixels are predicted as fire, above it none are."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "08825715",
   "metadata": {},
   "outputs": [],
   "source": [
    "# DummyClassifier requires 2D input\n",
    "X_train_dummy = np.zeros((len(y_train), 1))\n",
    "X_test_dummy  = np.zeros((len(y_test),  1))\n",
    "\n",
    "mc_model = DummyClassifier(strategy='prior', random_state=42)\n",
    "mc_model.fit(X_train_dummy, y_train)\n",
    "\n",
    "mc_pred = mc_model.predict(X_test_dummy)\n",
    "mc_fire_idx = list(mc_model.classes_).index(1)\n",
    "mc_probs = mc_model.predict_proba(X_test_dummy)[:, mc_fire_idx]\n",
    "\n",
    "print(\"=== MAJORITY CLASS BASELINE ===\")\n",
    "print(f\"Prior probability of fire (class 1): {mc_probs[0]:.4f}\")\n",
    "print(f\"Accuracy: {accuracy_score(y_test, mc_pred):.3f}\")\n",
    "print(classification_report(y_test, mc_pred,\n",
    "      target_names=['Not burned (0)', 'Burned (1)'], zero_division=0))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9c5ca82f",
   "metadata": {},
   "source": [
    "## Train models\n",
    "\n",
    "Each model is trained once with balanced class weights to handle class imbalance.\n",
    "The threshold sweep in the next cell then evaluates each model at 19 thresholds."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3947b4ee",
   "metadata": {},
   "outputs": [],
   "source": [
    "def predict_proba_chunked(model, X, fire_idx, chunk_size=CHUNK_SIZE):\n",
    "    \"\"\"Predict probabilities in chunks to avoid memory issues on large arrays.\"\"\"\n",
    "    probs = []\n",
    "    for i in range(0, len(X), chunk_size):\n",
    "        chunk = X[i:i + chunk_size]\n",
    "        probs.append(model.predict_proba(chunk)[:, fire_idx])\n",
    "    return np.concatenate(probs)\n",
    "\n",
    "\n",
    "# Random Forest\n",
    "rf = RandomForestClassifier(\n",
    "    n_estimators=50, random_state=42,\n",
    "    n_jobs=-1, class_weight='balanced', \n",
    "    max_depth=10 # For segTHRawS, reduce depth to speed up training\n",
    ")\n",
    "rf.fit(X_train, y_train)\n",
    "fire_idx_rf = list(rf.classes_).index(1)\n",
    "rf_probs = predict_proba_chunked(rf, X_test, fire_idx_rf)\n",
    "\n",
    "print(\"=== RANDOM FOREST (threshold 0.5) ===\")\n",
    "rf_pred_05 = (rf_probs >= 0.5).astype(int)\n",
    "print(classification_report(y_test, rf_pred_05,\n",
    "      target_names=['Not burned (0)', 'Burned (1)'], zero_division=0))\n",
    "\n",
    "# XGBoost\n",
    "xgb_ratio = (y_train == 0).sum() / (y_train == 1).sum()\n",
    "xgb = XGBClassifier(\n",
    "    n_estimators=50, max_depth=6, learning_rate=0.1,\n",
    "    random_state=42, n_jobs=-1,\n",
    "    scale_pos_weight=xgb_ratio, eval_metric='logloss'\n",
    ")\n",
    "xgb.fit(X_train, y_train)\n",
    "fire_idx_xgb = list(xgb.classes_).index(1)\n",
    "xgb_probs = predict_proba_chunked(xgb, X_test, fire_idx_xgb)\n",
    "\n",
    "print(\"=== XGBOOST (threshold 0.5) ===\")\n",
    "xgb_pred_05 = (xgb_probs >= 0.5).astype(int)\n",
    "print(classification_report(y_test, xgb_pred_05,\n",
    "      target_names=['Not burned (0)', 'Burned (1)'], zero_division=0))"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "1bbc41f1",
   "metadata": {},
   "source": [
    "## Threshold sweep"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "3efb6a28",
   "metadata": {},
   "outputs": [],
   "source": [
    "rf_results, xgb_results = [], []\n",
    "\n",
    "for t in THRESHOLDS:\n",
    "    rf_pred  = (rf_probs  >= t).astype(int)\n",
    "    xgb_pred = (xgb_probs >= t).astype(int)\n",
    "\n",
    "    rf_results.append({\n",
    "        'threshold': t,\n",
    "        'probs':     rf_probs,\n",
    "        'preds':     rf_pred,\n",
    "        'miou':      jaccard_score(y_test, rf_pred, zero_division=0),\n",
    "        'f1':        f1_score(y_test, rf_pred, zero_division=0),\n",
    "        'precision': precision_score(y_test, rf_pred, zero_division=0),\n",
    "        'recall':    recall_score(y_test, rf_pred, zero_division=0),\n",
    "        'accuracy':  accuracy_score(y_test, rf_pred),\n",
    "    })\n",
    "    xgb_results.append({\n",
    "        'threshold': t,\n",
    "        'probs':     xgb_probs,\n",
    "        'preds':     xgb_pred,\n",
    "        'miou':      jaccard_score(y_test, xgb_pred, zero_division=0),\n",
    "        'f1':        f1_score(y_test, xgb_pred, zero_division=0),\n",
    "        'precision': precision_score(y_test, xgb_pred, zero_division=0),\n",
    "        'recall':    recall_score(y_test, xgb_pred, zero_division=0),\n",
    "        'accuracy':  accuracy_score(y_test, xgb_pred),\n",
    "    })\n",
    "\n",
    "print(f\"Done — {len(THRESHOLDS)} thresholds evaluated.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "0eb7e83c",
   "metadata": {},
   "outputs": [],
   "source": [
    "# === EXPERIMENT: cost-sensitive training per threshold ===\n",
    "# Test of de \"19x trainen\" aanpak hier wel een logische piek geeft,\n",
    "# aangezien brand hier de minderheidsklasse is (~28%) in plaats van de\n",
    "# meerderheidsklasse zoals bij THRawS.\n",
    "\n",
    "rf_results_cs, xgb_results_cs = [], []\n",
    "\n",
    "for t in THRESHOLDS:\n",
    "    pos_weight = np.clip((1 - t) / t, 0.3, 3)\n",
    "\n",
    "    rf_cs = RandomForestClassifier(\n",
    "        n_estimators=50, random_state=42, n_jobs=-1,\n",
    "        class_weight={0: 1.0, 1: pos_weight}\n",
    "    )\n",
    "    rf_cs.fit(X_train, y_train)\n",
    "    fire_idx = list(rf_cs.classes_).index(1)\n",
    "    rf_prob_cs = predict_proba_chunked(rf_cs, X_test, fire_idx)\n",
    "    rf_pred_cs = (rf_prob_cs >= 0.5).astype(int)\n",
    "\n",
    "    rf_results_cs.append({\n",
    "        'threshold':  t,\n",
    "        'pos_weight': pos_weight,\n",
    "        'miou':       jaccard_score(y_test, rf_pred_cs, zero_division=0),\n",
    "        'f1':         f1_score(y_test, rf_pred_cs, zero_division=0),\n",
    "        'precision':  precision_score(y_test, rf_pred_cs, zero_division=0),\n",
    "        'recall':     recall_score(y_test, rf_pred_cs, zero_division=0),\n",
    "    })\n",
    "\n",
    "    xgb_cs = XGBClassifier(\n",
    "        n_estimators=50, max_depth=6, learning_rate=0.1,\n",
    "        random_state=42, n_jobs=-1,\n",
    "        scale_pos_weight=pos_weight, eval_metric='logloss'\n",
    "    )\n",
    "    xgb_cs.fit(X_train, y_train)\n",
    "    fire_idx_xgb = list(xgb_cs.classes_).index(1)\n",
    "    xgb_prob_cs = predict_proba_chunked(xgb_cs, X_test, fire_idx_xgb)\n",
    "    xgb_pred_cs = (xgb_prob_cs >= 0.5).astype(int)\n",
    "\n",
    "    xgb_results_cs.append({\n",
    "        'threshold':  t,\n",
    "        'pos_weight': pos_weight,\n",
    "        'miou':       jaccard_score(y_test, xgb_pred_cs, zero_division=0),\n",
    "        'f1':         f1_score(y_test, xgb_pred_cs, zero_division=0),\n",
    "        'precision':  precision_score(y_test, xgb_pred_cs, zero_division=0),\n",
    "        'recall':     recall_score(y_test, xgb_pred_cs, zero_division=0),\n",
    "    })\n",
    "\n",
    "print(f\"{'Threshold':>10} {'PosWeight':>10} {'mIoU':>8} {'F1':>8} {'Precision':>10} {'Recall':>8}\")\n",
    "print(\"-\" * 60)\n",
    "for r in rf_results_cs:\n",
    "    print(f\"  {r['threshold']:>8.2f} {r['pos_weight']:>10.3f} {r['miou']:>8.3f} \"\n",
    "          f\"{r['f1']:>8.3f} {r['precision']:>10.3f} {r['recall']:>8.3f}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "48a4f876",
   "metadata": {},
   "source": [
    "## Result overview"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "db7bda15",
